<script>
document.querySelectorAll('a.btn[href*="/download/"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var last = localStorage.getItem('timermo_visit');
        var now = Date.now();
        if (!last || now - last > 86400000) {
            window.open('https://www.timermo.com/?utm_source=tooplate&utm_medium=download&utm_campaign=redirect', '_blank');
            localStorage.setItem('timermo_visit', now);
        }
    });
